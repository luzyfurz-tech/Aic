rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: commands
    // Fields:
    //   - command: string (required)
    //   - timestamp: timestamp (required)
    //   - status: string (required, enum: pending, executing, completed, failed)
    //   - uid: string (required, owner)
    //
    // Collection: responses
    // Fields:
    //   - commandId: string (required)
    //   - output: string (required)
    //   - error: string (optional)
    //   - timestamp: timestamp (required)
    //   - uid: string (required, owner)
    //
    // Collection: filesystem
    // Fields:
    //   - name: string (required)
    //   - type: string (required, enum: file, dir)
    //   - size: number (optional)
    //   - date: string (required)
    //   - parentId: string (optional)
    //   - content: string (optional)
    //   - uid: string (required, owner)
    //
    // Collection: pi_status
    // Fields:
    //   - online: bool (required)
    //   - lastSeen: timestamp (required)
    //   - hostname: string (optional)
    //   - os: string (optional)
    //   - uid: string (required, owner)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "snoopsterdk@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidCommand(data) {
      return data.command is string && data.command.size() > 0 && data.command.size() < 5000 &&
             data.status in ['pending', 'executing', 'completed', 'failed'] &&
             data.timestamp is timestamp;
    }

    function isValidResponse(data) {
      return data.commandId is string &&
             data.output is string && data.output.size() < 100000 &&
             data.timestamp is timestamp;
    }

    function isValidFileEntry(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 255 &&
             data.type in ['file', 'dir'] &&
             data.date is string;
    }

    function isValidPiStatus(data) {
      return data.online is bool &&
             data.lastSeen is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /commands/{commandId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidCommand(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidCommand(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /responses/{responseId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidResponse(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidResponse(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /filesystem/{fileId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidFileEntry(request.resource.data) && uidUnchanged();
      allow update: if (isDocOwner() || isAdmin()) && isValidFileEntry(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /pi_status/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidPiStatus(request.resource.data);
      allow update: if (isOwner(uid) || isAdmin()) && isValidPiStatus(request.resource.data);
      allow delete: if isOwner(uid) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }
  }
}
